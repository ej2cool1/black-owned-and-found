datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model Business {
  id            Int       @id @default(autoincrement())
  name          String
  category      String
  city          String
  state         String
  description   String?
  website       String?
  createdAt     DateTime  @default(now())

  @@unique([name, city, state])
}